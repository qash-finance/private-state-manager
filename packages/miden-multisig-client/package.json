{
  "name": "@openzeppelin/miden-multisig-client",
  "version": "0.12.8",
  "description": "TypeScript SDK for Miden multisig accounts with PSM integration",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "masm"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@miden-sdk/miden-sdk": "^0.13.0",
    "@noble/hashes": "^2.0.1",
    "@openzeppelin/psm-client": "file:../psm-client"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
