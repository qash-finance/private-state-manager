: "${PSM_HTTP_PORT:=3000}"
: "${PSM_GRPC_PORT:=50051}"
: "${PSM_NETWORK_TYPE:=MidenLocal}"
: "${PSM_RATE_BURST_PER_SEC:=200}"
: "${PSM_RATE_PER_MIN:=5000}"
: "${PSM_MAX_REQUEST_BYTES:=1048576}"
: "${PSM_CANONICALIZATION_ENABLED:=false}"
: "${PSM_CANONICALIZATION_CHECK_INTERVAL_SECS:=10}"
: "${PSM_CANONICALIZATION_MAX_RETRIES:=18}"
: "${PSM_SERVER_START_TIMEOUT_SECS:=600}"
: "${BENCH_SKIP_PREBUILD:=false}"
: "${BENCH_SERVER_LOG_LEVEL:=error}"

: "${BENCH_USERS:=4}"
: "${BENCH_ACCOUNTS:=8}"
: "${BENCH_SIGNERS_PER_ACCOUNT:=2}"
: "${BENCH_AUTH_SCHEME:=falcon}"
: "${BENCH_TRANSPORT:=grpc}"
: "${BENCH_OPS_PER_USER:=32}"
: "${BENCH_MIXED_WRITE_PERCENT:=30}"
: "${BENCH_STATE_SYNC_READS_PER_PUSH:=4}"
: "${BENCH_SCENARIOS:=}"

: "${BENCH_SAMPLE_INTERVAL_SECS:=1}"
: "${BENCH_ENABLE_CANONICALIZATION:=false}"
: "${BENCH_CANONICALIZATION_POLL_INTERVAL_MS:=250}"
: "${BENCH_CANONICALIZATION_TIMEOUT_SECS:=90}"
